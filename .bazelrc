# Write build outputs in a platform-specific directory;
# avoid outputs being wiped and rewritten when switching between platforms.
common --experimental_platform_in_output_dir
# Use a symlink prefix to avoid clobbering the workspace root.
build --symlink_prefix=.bazel/
# buf_generate may fetch BSR modules / go tool binaries (pins remain in buf.lock + go.sum).
build --sandbox_default_allow_network=true
